jobs:
  ios:
    runs-on: macos-26
    steps:
      - uses: actions/checkout@v4

      # … toutes les étapes d'installation et build de ton app

      - name: Build iOS app (Release)
        run: |
          set -o pipefail
          xcodebuild \
            -workspace ios/Papillon.xcworkspace \
            -scheme Papillon \
            -configuration Release \
            -sdk iphoneos \
            -destination 'generic/platform=iOS' \
            CODE_SIGNING_ALLOWED=NO \
            clean archive \
            -archivePath ios/build/Papillon.xcarchive

      - name: Export IPA
        run: |
          xcodebuild -exportArchive \
            -archivePath ios/build/Papillon.xcarchive \
            -exportOptionsPlist ios/exportOptions.plist \
            -exportPath ios/build